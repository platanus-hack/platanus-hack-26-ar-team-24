# ============================================
# Platanus Hack 26 — Environment Variables
# ============================================
# Copiá este archivo como .env.local y completá los valores

# --- Supabase (Backend: Luca + Ale) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (IA: Román) ---
OPENAI_API_KEY=

# --- OpenClaw Runtime ---
ADMIN_API_TOKEN=change-me-admin-token
OPENCLAW_ADMIN_API_TOKEN=change-me-admin-token
OPENCLAW_GATEWAY_TOKEN=change-me-gateway-token
OPENCLAW_DEFAULT_MODEL=openai/gpt-5-nano
OPENCLAW_RUNTIME_URL=http://localhost:8080

# --- AI Engine Service (IA: Román → Railway) ---
NEXT_PUBLIC_AI_ENGINE_URL=http://localhost:3001

# --- General ---
NODE_ENV=development
